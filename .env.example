# --- Base de données (Supabase / Postgres) ---
# Connection string du POOLER Supabase (mode transaction, port 6543).
# Supabase > Project Settings > Database > Connection string > "Transaction pooler".
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-west-3.pooler.supabase.com:6543/postgres

# --- Supabase Auth (protège /admin uniquement) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Clé service_role : côté serveur uniquement, JAMAIS exposée au client.
# Optionnelle pour le MVP (les écritures admin passent par Drizzle/DATABASE_URL).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- SEO ---
# URL de production (sans slash final), utilisée par sitemap/robots/OpenGraph.
NEXT_PUBLIC_SITE_URL=https://kaboz-deal.vercel.app
